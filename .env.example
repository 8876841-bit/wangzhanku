# ── 必填 ────────────────────────────────────────────────────────────────────
# MySQL 数据库连接（Railway 会自动提供，也可手动填写）
DATABASE_URL=mysql://user:password@host:3306/dbname

# 管理员登录密码（你自己设置，用于访问网站）
ADMIN_PASSWORD=your-secret-password-here

# JWT 签名密钥（随机字符串，越长越安全）
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── 可选 ────────────────────────────────────────────────────────────────────
# GitHub Token 加密密钥（32字节随机字符串，用于加密存储 GitHub Token）
ENCRYPTION_KEY=your-32-byte-random-encryption-key

# Node 环境（Railway 自动设置，无需手动填写）
# NODE_ENV=production
